# ── devora env template ──────────────────────────────────────────────────
# Copy to `.env.local` and fill in real values. All values except the two
# NEXT_PUBLIC_* Supabase ones are server-only and must never be exposed to the
# browser. Every integration degrades gracefully when its vars are absent, so
# local dev / previews still run (chat falls back to a canned reply, email logs
# instead of sending, etc.).

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key are safe to expose (needed for browser Realtime).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key BYPASSES row-level security — server-only, keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional model overrides (defaults are set in lib/anthropic.ts).
# ANTHROPIC_CHAT_MODEL=claude-sonnet-5
# ANTHROPIC_SUMMARY_MODEL=claude-opus-4-8

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Optional: without these, rate limiting is skipped (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Zoho Mail SMTP (lead + support + contact emails) ────────────────────────
# App-specific password, NOT your login password. Without these the email
# routes validate + log instead of sending (matches the existing contact route).
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
# Where lead/support notifications land (defaults to ZOHO_SMTP_USER).
CONTACT_TO=
