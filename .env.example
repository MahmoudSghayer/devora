# Zoho Mail SMTP — contact form delivery.
# Create an APP-SPECIFIC password in Zoho: Settings → Security → App Passwords
# (do NOT use your normal account password). Copy this file to .env.local.
ZOHO_SMTP_USER=you@devora.design
ZOHO_SMTP_PASS=your-app-specific-password
CONTACT_TO=you@devora.design

# Optional SMTP overrides (defaults shown). Use the host for your Zoho region,
# e.g. smtp.zoho.com (US), smtp.zoho.eu (EU), smtp.zoho.in (IN).
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
